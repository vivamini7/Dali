# GROQ API 키 (무료 발급: https://console.groq.com)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Render 운영 환경에서는 production으로 설정
APP_ENV=development

# 허용할 프론트 주소. 여러 개면 쉼표로 구분
FRONTEND_ORIGINS=http://localhost:5173

# Supabase Postgres 연결 문자열 (설정 시 회원/이용권/사용량 데이터가 영구 저장됨)
# 비밀번호에 특수문자가 있으면 URL 인코딩 필요 (예: ! -> %21)
DATABASE_URL=postgresql://postgres:xxxx@db.xxxx.supabase.co:5432/postgres

# 이미지 번역 API (선택)
DEEPL_API_KEY=

# GET /client-error (수집된 프론트엔드 오류 로그 조회)에 필요한 관리자 토큰
ADMIN_TOKEN=xxxxxxxxxxxxxxxx

# 앱스토어/플레이스토어 인앱결제 검증용 (네이티브 결제 단계에서 설정)
APPLE_SHARED_SECRET=
GOOGLE_PACKAGE_NAME=
GOOGLE_SERVICE_ACCOUNT_JSON=
